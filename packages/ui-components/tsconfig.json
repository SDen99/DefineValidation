{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "lib": ["DOM", "ES2022"],
    "moduleResolution": "bundler",
    "target": "ES2022",
    "module": "ES2022",
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"]
}