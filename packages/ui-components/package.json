{
  "name": "@sden99/ui-components",
  "version": "0.1.0",
  "description": "Reusable UI components for clinical data applications",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "svelte": "./dist/index.js",
  "exports": {
    ".": {
      "svelte": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./theme.css": "./dist/theme.css",
    "./utils": {
      "import": "./dist/utils.js",
      "types": "./dist/utils.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "svelte-package -w",
    "build": "svelte-package",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "package": "svelte-package"
  },
  "peerDependencies": {
    "@lucide/svelte": "^0.526.0",
    "bits-ui": "^2.8.13",
    "clsx": "^2.0.0",
    "svelte": "^5.0.0",
    "tailwind-merge": "^2.0.0",
    "tailwind-variants": "^0.2.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.4",
    "tailwind-variants": "^0.2.1"
  },
  "devDependencies": {
    "@internationalized/date": "^3.10.0",
    "@sveltejs/package": "^2.3.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "bits-ui": "^2.8.13",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.8.3",
    "vite": "^5.0.0"
  },
  "keywords": [
    "svelte",
    "ui-components",
    "design-system",
    "clinical-data",
    "tailwind"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/ui-components"
  }
}