{
  "name": "@sden99/validation-engine",
  "version": "0.1.0",
  "description": "TypeScript validation engine for clinical data, compatible with CDISC Rules Engine format",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
