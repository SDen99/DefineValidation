{
  "name": "@sden99/vlm-components",
  "version": "0.1.0",
  "description": "Variable-Level Metadata UI components for clinical data visualization",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write \"src/**/*.{js,ts,svelte,json,md}\""
  },
  "dependencies": {
    "@sden99/cdisc-types": "workspace:*",
    "@sden99/dataset-domain": "workspace:*",
    "@sden99/ui-components": "workspace:*",
    "@sden99/vlm-processing": "workspace:*"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@types/node": "^24.1.0",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.0.0",
    "svelte": "^5.41.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "svelte": "^5.0.0",
    "typescript": "^5.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./components/*.svelte": {
      "svelte": "./src/components/*.svelte",
      "types": "./src/components/*.svelte"
    },
    "./components/VLMView/*.svelte": {
      "svelte": "./src/components/VLMView/*.svelte",
      "types": "./src/components/VLMView/*.svelte"
    },
    "./components/VLMView/cells/*.svelte": {
      "svelte": "./src/components/VLMView/cells/*.svelte",
      "types": "./src/components/VLMView/cells/*.svelte"
    },
    "./state": {
      "types": "./dist/state/index.d.ts",
      "import": "./dist/state/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SDen99/DatasetViewer.git",
    "directory": "packages/vlm-components"
  },
  "keywords": [
    "vlm",
    "variable-level-metadata",
    "clinical-data",
    "cdisc",
    "svelte-components",
    "ui-components"
  ],
  "author": "Densham",
  "license": "ISC"
}