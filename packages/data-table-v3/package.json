{
  "name": "@sden99/data-table-v3",
  "version": "0.1.0",
  "description": "Event-driven data table with Svelte 5 - Clean architecture, no reactive loops",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "svelte": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "svelte-package",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest",
    "test:run": "vitest --run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --run --coverage"
  },
  "dependencies": {
    "@sden99/table-components": "workspace:*",
    "bits-ui": "^2.9.9",
    "@lucide/svelte": "^0.526.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^3.0.0",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/package": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^6.1.0",
    "@testing-library/svelte": "^5.0.0",
    "@vitest/ui": "^2.0.0",
    "happy-dom": "^20.0.10",
    "jsdom": "^27.2.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^7.0.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "svelte",
    "svelte5",
    "data-table",
    "event-driven",
    "performance",
    "clinical-data",
    "no-loops"
  ]
}
