{
  "name": "app",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "diag": "node ./tailwind-diag.js",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "svelte-kit": "svelte-kit",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write \"src/**/*.{js,ts,svelte,css,html,json,md}\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "analyze": "depcruise --include-only '^src' --output-type dot src | dot -T svg > dependency-graph.svg",
    "docs:core": "typedoc src/lib/core/**/*.ts --exclude **/*.svelte",
    "docs:all": "typedoc",
    "find-types": "NODE_ENV=development node --loader ts-node/esm src/scripts/find-types.ts",
    "propertyChecker": "NODE_ENV=development node --loader ts-node/esm src/scripts/propertyChecker.ts"
  },
  "devDependencies": {
    "@internationalized/date": "^3.10.0",
    "@lucide/svelte": "^0.526.0",
    "@sveltejs/adapter-auto": "^6.0.1",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.26.1",
    "@sveltejs/vite-plugin-svelte": "^6.1.0",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/postcss": "^4.1.11",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/svelte": "^5.2.8",
    "@types/eslint": "^9.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.1.0",
    "autoprefixer": "^10.4.21",
    "bits-ui": "^2.9.9",
    "clsx": "^2.1.1",
    "csstype": "^3.1.3",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.11.0",
    "globals": "^16.3.0",
    "postcss": "^8.5.6",
    "prettier-plugin-svelte": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "svelte": "5.41.3",
    "svelte-check": "^4.3.0",
    "tailwind-merge": "^3.3.1",
    "tailwind-variants": "^1.0.0",
    "tailwindcss": "^4.1.11",
    "tailwindcss-animate": "^1.0.7",
    "terser": "^5.43.1",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.7",
    "typedoc-plugin-markdown": "^4.7.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vite": "^7.0.6",
    "vite-plugin-inspect": "^11.3.0",
    "vitest": "^3.2.4",
    "js-yaml": "^4.1.1",
    "pyodide": "^0.28.0"
  },
  "dependencies": {
    "@sden99/cdisc-types": "workspace:*",
    "@sden99/data-processing": "workspace:*",
    "@sden99/data-table-v3": "workspace:*",
    "@sden99/dataset-domain": "workspace:*",
    "@sden99/metadata-components": "workspace:*",
    "@sden99/table-components": "workspace:*",
    "@sden99/ui-components": "workspace:*",
    "@sden99/validation-engine": "workspace:*",
    "@sden99/worker-communication": "workspace:*"
  },
  "description": "Everything you need to build a Svelte project, powered by [`create-svelte`](https://github.com/sveltejs/kit/tree/main/packages/create-svelte).",
  "main": "index.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SDen99/DatasetViewer.git"
  },
  "author": "Densham",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/SDen99/DatasetViewer/issues"
  },
  "homepage": "https://github.com/SDen99/DatasetViewer#readme"
}
