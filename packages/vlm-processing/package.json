{
  "name": "@sden99/vlm-processing",
  "version": "0.1.0",
  "description": "Variable-Level Metadata processing, stratification analysis, and UI components for clinical data",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write \"src/**/*.{js,ts,json,md}\""
  },
  "dependencies": {
    "@sden99/cdisc-types": "workspace:*",
    "@sden99/dataset-domain": "workspace:*",
    "@sden99/data-processing": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.1.0",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "svelte": "^5.0.0",
    "typescript": "^5.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./algorithms": {
      "types": "./dist/algorithms/index.d.ts",
      "import": "./dist/algorithms/index.js"
    },
    "./stratification": {
      "types": "./dist/stratification/index.d.ts",
      "import": "./dist/stratification/index.js"
    },
    "./analysis": {
      "types": "./dist/analysis/index.d.ts",
      "import": "./dist/analysis/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./components/*.svelte": {
      "svelte": "./src/components/*.svelte",
      "types": "./src/components/*.svelte"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SDen99/DatasetViewer.git",
    "directory": "packages/vlm-processing"
  },
  "keywords": [
    "vlm",
    "variable-level-metadata",
    "clinical-data",
    "cdisc",
    "stratification",
    "data-analysis",
    "svelte-components"
  ],
  "author": "Densham",
  "license": "ISC"
}